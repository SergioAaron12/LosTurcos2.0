rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla temporal para prototipo: permite leer y escribir productos desde la tienda.
    // Conviene endurecer esto con Firebase Auth antes de producción.
    match /products/{productId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}